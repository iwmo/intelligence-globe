# PostgreSQL
POSTGRES_DB=opensignal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Backend
FRONTEND_ORIGIN=http://localhost:3000
VERSION=0.1.0

# API Authentication — used by Phase 28 middleware to protect write endpoints
API_KEY=your-secret-api-key
# Frontend API key — must match API_KEY; sent as X-API-Key header when submitting OSINT events
VITE_API_KEY=your-secret-api-key

# OpenSky Network OAuth2 — register at https://opensky-network.org/
OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# AISStream.io — get your key at https://aisstream.io/
AISSTREAM_API_KEY=your-aisstream-api-key

# Cesium Ion — get your free token at https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=your-cesium-ion-token

# Frontend
VITE_API_BASE_URL=http://localhost:8000
